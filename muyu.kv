#:kivy 2.3.0

# Apple 风格电子木鱼
<WoodenFishLayout>:
    orientation: 'vertical'
    padding: 20
    spacing: 12

    # 顶部标题
    Label:
        text: '电子木鱼'
        font_name: 'NotoSansCJK'
        font_size: '26sp'
        color: 0.12, 0.12, 0.14, 1
        size_hint_y: 0.08
        halign: 'center'
        valign: 'middle'

    Label:
        text: 'Wooden Fish'
        font_size: '12sp'
        color: 0.47, 0.47, 0.50, 1
        size_hint_y: 0.04

    # 功德计数卡片
    RelativeLayout:
        size_hint_y: 0.22
        canvas.before:
            Color:
                rgba: 0.97, 0.97, 0.98, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [16, 16, 16, 16]

        BoxLayout:
            pos: root.pos
            orientation: 'vertical'
            padding: 10
            spacing: 4

            Label:
                text: '功德累计'
                font_name: 'NotoSansCJK'
                font_size: '14sp'
                color: 0.47, 0.47, 0.50, 1
                size_hint_y: 0.4
                halign: 'center'

            Label:
                id: gongde_label
                text: '功德: 0  次'
                font_name: 'NotoSansCJK'
                font_size: '48sp'
                color: 1.0, 0.70, 0.0, 1
                size_hint_y: 0.6
                halign: 'center'
                bold: True

    # 木鱼按钮区域
    RelativeLayout:
        size_hint_y: 0.50

        FishButton:
            id: fish_widget
            size_hint: 0.9, 0.9
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}

    # 按钮行
    BoxLayout:
        size_hint_y: 0.08
        spacing: 15

        Button:
            text: '重置功德'
            font_name: 'NotoSansCJK'
            font_size: '14sp'
            background_color: 0.78, 0.78, 0.80, 1
            color: 0.20, 0.20, 0.22, 1
            on_release: app.reset()

        Button:
            text: '敲一下'
            font_name: 'NotoSansCJK'
            font_size: '14sp'
            background_color: 1.0, 0.70, 0.0, 1
            color: 0.97, 0.97, 0.97, 1
            on_release: fish_widget.on_tap(fish_widget, {'pos': fish_widget.center})

    # 底部提示
    RelativeLayout:
        size_hint_y: 0.08
        canvas.before:
            Color:
                rgba: 0.97, 0.97, 0.98, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [12, 12, 12, 12]

        Label:
            text: '点击木鱼增加功德  ·  按 R 重置'
            font_name: 'NotoSansCJK'
            font_size: '12sp'
            color: 0.47, 0.47, 0.50, 1
            center: self.parent.center
            halign: 'center'
            valign: 'middle'
